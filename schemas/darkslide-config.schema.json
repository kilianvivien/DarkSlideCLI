{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://darkslide.local/schemas/darkslide-config.schema.json",
  "title": "DarkSlide CLI Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "input": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      ]
    },
    "outputDir": { "type": "string", "minLength": 1 },
    "profile": { "type": "string", "minLength": 1 },
    "format": { "enum": ["jpeg", "jpg", "png", "webp", "tiff"] },
    "quality": { "type": "integer", "minimum": 1, "maximum": 100 },
    "maxDimension": {
      "oneOf": [
        { "type": "null" },
        { "type": "integer", "minimum": 1 }
      ]
    },
    "overwrite": { "type": "boolean" },
    "dryRun": { "type": "boolean" },
    "json": { "type": "boolean" },
    "concurrency": { "type": "integer", "minimum": 1 },
    "saveSidecar": { "type": "boolean" },
    "auto": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filmBase": { "type": "boolean" },
        "flare": { "type": "boolean" },
        "exposure": { "type": "boolean" },
        "whiteBalance": { "type": "boolean" }
      }
    },
    "naming": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "suffix": { "type": "string" }
      }
    },
    "settings": { "$ref": "#/$defs/conversionSettings" }
  },
  "$defs": {
    "curvePoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "curve": {
      "type": "array",
      "items": { "$ref": "#/$defs/curvePoint" }
    },
    "conversionSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exposure": { "type": "number" },
        "contrast": { "type": "number" },
        "saturation": { "type": "number" },
        "shadowRecovery": { "type": "number" },
        "midtoneContrast": { "type": "number" },
        "flareCorrection": { "type": "number" },
        "temperature": { "type": "number" },
        "tint": { "type": "number" },
        "redBalance": { "type": "number" },
        "greenBalance": { "type": "number" },
        "blueBalance": { "type": "number" },
        "blackPoint": { "type": "number" },
        "whitePoint": { "type": "number" },
        "highlightProtection": { "type": "number" },
        "curves": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rgb": { "$ref": "#/$defs/curve" },
            "red": { "$ref": "#/$defs/curve" },
            "green": { "$ref": "#/$defs/curve" },
            "blue": { "$ref": "#/$defs/curve" }
          }
        },
        "rotation": { "type": "number" },
        "levelAngle": { "type": "number" },
        "crop": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "width": { "type": "number" },
            "height": { "type": "number" },
            "aspectRatio": {
              "oneOf": [
                { "type": "number" },
                { "type": "null" }
              ]
            }
          }
        },
        "filmBaseSample": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["r", "g", "b"],
              "properties": {
                "r": { "type": "number" },
                "g": { "type": "number" },
                "b": { "type": "number" }
              }
            }
          ]
        },
        "residualBaseCorrection": { "type": "boolean" },
        "blackAndWhite": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "redMix": { "type": "number" },
            "greenMix": { "type": "number" },
            "blueMix": { "type": "number" },
            "tone": { "type": "number" }
          }
        },
        "sharpen": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "radius": { "type": "number" },
            "amount": { "type": "number" }
          }
        },
        "noiseReduction": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "luminanceStrength": { "type": "number" }
          }
        },
        "dustRemoval": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "autoEnabled": { "type": "boolean" },
            "autoDetectMode": { "enum": ["spots", "scratches", "both"] },
            "autoSensitivity": { "type": "number" },
            "autoMaxRadius": { "type": "number" },
            "manualBrushRadius": { "type": "number" },
            "marks": { "type": "array" }
          }
        }
      }
    }
  }
}
